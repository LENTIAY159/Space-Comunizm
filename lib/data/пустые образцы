  // Пример 1: Оружие с простыми правилами (без параметров)
  final bolter = Weapon(
    name: 'Bolter',
    profiles: [
      WeaponProfile(
        range: '24"',
        attacks: '2',
        hit: '3+',
        strength: '4',
        ap: '0',
        damage: '1',
        specialRules: [
          WeaponAbility.rapidFire, // Используем enum напрямую
          WeaponAbility.lethalHits,
        ],
        specialRuleDetails: {
          WeaponAbility.rapidFire: {'value': '1'}, // Для Rapid Fire 1
        },
      ),
    ],
  );

  // Пример 2: Оружие с несколькими экземплярами одного правила
  final multiMeltagun = Weapon(
    name: 'Multi-Meltagun',
    profiles: [
      WeaponProfile(
        range: '18"',
        attacks: '2',
        hit: '3+',
        strength: '9',
        ap: '-4',
        damage: 'D6',
        specialRules: [
          // Два разных Anti правила с уникальными ID
          WeaponAbilityKeys.createWithId(WeaponAbility.anti, 'vehicle'),
          WeaponAbilityKeys.createWithId(WeaponAbility.anti, 'monster'),
          WeaponAbility.melta, // Обычное правило
        ],
        specialRuleDetails: {
          // Ключи должны точно соответствовать тем, что в specialRules
          WeaponAbilityKeys.createWithId(WeaponAbility.anti, 'vehicle'): {
            'type': 'VEHICLE',
            'value': '3+',
          },
          WeaponAbilityKeys.createWithId(WeaponAbility.anti, 'monster'): {
            'type': 'MONSTER',
            'value': '4+',
          },
          WeaponAbility.melta: {'value': '2'},
        },
      ),
    ],
  );

